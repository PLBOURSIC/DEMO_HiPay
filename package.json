{
  "name": "demo-hipay",
  "version": "1.0.0",
  "description": "Tests automatisés HiPay avec Cucumber",
  "scripts": {
    "test": "cucumber-js --format json:reports/cucumber.json && node reports/generate-report.js",
    "test:cas_nominal_OK": "cucumber-js features/cas_nominal_OK.feature --format json:reports/cucumber.json && node reports/generate-report.js",
    "test:authentification_KO": "cucumber-js features/authentification_KO.feature --format json:reports/cucumber.json && node reports/generate-report.js",
    "test:all": "cucumber-js features/**/*.feature --format json:reports/cucumber.json && node reports/generate-report.js",
    "test:smoke": "cucumber-js --tags @smoke --format json:reports/cucumber.json && node reports/generate-report.js"
  },
  "dependencies": {
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.0.0",
    "chai": "^4.3.10",
    "cucumber-html-reporter": "^7.2.0",
    "dotenv": "^16.3.1"
  }
}

{
  "name": "demo-hipay",
  "version": "1.0.0",
  "description": "Tests automatisés HiPay avec Cucumber",
  "scripts": {
    "test": "node features/support-scripts/run-tests.js",
    "report": "node reports/generate-report.js",
    "test:cas_nominal_OK": "node features/support-scripts/run-tests.js features/cas_nominal_OK.feature",
    "test:authentification_KO": "node features/support-scripts/run-tests.js features/authentification_KO.feature",
    "test:all": "node features/support-scripts/run-tests.js features/",
    "test:smoke": "node features/support-scripts/run-tests.js --tags @smoke",
    "test:demo": "node features/support-scripts/run-tests.js --tags @demo",
    "test:regression": "node features/support-scripts/run-tests.js --tags @non_regression",
    "test:non_regression": "node features/support-scripts/run-tests.js --tags @non_regression",
    "test:CP": "node features/support-scripts/run-tests.js --tags @CP",
    "test:CNP": "node features/support-scripts/run-tests.js --tags @CNP"
  },
  "dependencies": {
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.0.0",
    "chai": "^4.3.10",
    "cucumber-html-reporter": "^7.2.0",
    "dotenv": "^16.3.1"
  }
}
